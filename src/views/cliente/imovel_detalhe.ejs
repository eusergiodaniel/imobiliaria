<%- include('../partials/head', { title: imovel.titulo }) %>
<%- include('../partials/sidebar_cliente') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0 bg-slate-50">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center gap-3 sticky top-14 lg:top-0 z-20">
    <a href="/cliente/imoveis" class="text-slate-400 hover:text-slate-600 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800 truncate"><%= imovel.titulo %></h1>
      <p class="text-xs text-slate-500"><%= imovel.bairro %>, <%= imovel.cidade %></p>
    </div>
  </header>

  <main class="p-4 lg:p-8 max-w-3xl mx-auto">
    <% if (msg) { %>
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <%= msg %>
    </div>
    <% } %>
    <% if (erro) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"><%= erro %></div>
    <% } %>

    <% const imgMap = { apartamento: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&q=80', casa: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800&q=80', comercial: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80', terreno: 'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=800&q=80' } %>

    <!-- Foto principal -->
    <div class="h-56 lg:h-72 rounded-xl overflow-hidden mb-5 relative">
      <img src="<%= imovel.fotoUrl || imgMap[imovel.tipo] %>" class="w-full h-full object-cover"/>
      <span class="absolute top-3 right-3 text-sm px-3 py-1 rounded-full font-semibold
        <%= imovel.status === 'disponivel' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600' %>">
        <%= imovel.status %>
      </span>
    </div>

    <!-- Info -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 mb-4">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="text-xs text-slate-400 uppercase font-semibold mb-1"><%= imovel.tipo %></div>
          <h2 class="text-lg font-bold text-slate-800"><%= imovel.titulo %></h2>
          <p class="text-sm text-slate-500">📍 <%= imovel.endereco %>, <%= imovel.bairro %> — <%= imovel.cidade %></p>
        </div>
        <div class="text-right">
          <div class="text-brand-600 font-bold text-xl">R$ <%= imovel.preco.toLocaleString('pt-BR') %></div>
          <div class="text-xs text-slate-400"><%= imovel.area %> m²</div>
        </div>
      </div>
      <% if (imovel.descricao) { %>
      <div class="border-t border-slate-100 pt-4">
        <h3 class="text-xs font-semibold text-slate-600 uppercase tracking-wide mb-2">Descrição</h3>
        <p class="text-sm text-slate-600 leading-relaxed"><%= imovel.descricao %></p>
      </div>
      <% } %>
    </div>

    <!-- Agendar visita -->
    <% if (imovel.status === 'disponivel' && clienteId) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
      <h3 class="font-semibold text-slate-800 mb-1">📅 Agendar uma visita</h3>
      <p class="text-xs text-slate-500 mb-4">Escolha uma data e horário para conhecer este imóvel</p>
      <form method="POST" action="/cliente/imoveis/<%= imovel.id %>/visita" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Data e Hora *</label>
          <input type="datetime-local" name="dataHora" required
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Observação</label>
          <textarea name="observacao" rows="2" placeholder="Alguma preferência ou dúvida?"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-semibold py-2.5 rounded-lg transition text-sm">
          Solicitar Visita
        </button>
      </form>
    </div>
    <% } else if (!clienteId) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-center">
      <p class="text-sm text-amber-700">⚠️ Seu cadastro de cliente ainda não foi criado pelo agente. Entre em contato com a imobiliária para agendar uma visita.</p>
    </div>
    <% } else if (imovel.status !== 'disponivel') { %>
    <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 text-center">
      <p class="text-sm text-slate-500">Este imóvel não está disponível para visitas no momento.</p>
    </div>
    <% } %>
  </main>
</div>
</body></html>
