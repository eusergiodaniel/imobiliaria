<%- include('../partials/head', { title: 'Minhas Visitas' }) %>
<%- include('../partials/sidebar_cliente') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0 bg-slate-50">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 sticky top-14 lg:top-0 z-20">
    <h1 class="text-base lg:text-lg font-semibold text-slate-800">Minhas Visitas</h1>
    <p class="text-xs text-slate-500"><%= visitas.length %> visitas registradas</p>
  </header>

  <main class="p-4 lg:p-8">
    <% if (visitas.length === 0) { %>
      <div class="text-center py-16 text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-sm mb-3">Nenhuma visita agendada</p>
        <a href="/cliente/imoveis" class="text-sm bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition">Ver imóveis disponíveis</a>
      </div>
    <% } %>

    <div class="flex flex-col gap-3">
      <% visitas.forEach(v => { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl flex-shrink-0 flex items-center justify-center
          <%= v.status === 'agendada' ? 'bg-yellow-50' : v.status === 'realizada' ? 'bg-green-50' : 'bg-red-50' %>">
          <svg class="w-6 h-6 <%= v.status === 'agendada' ? 'text-yellow-500' : v.status === 'realizada' ? 'text-green-500' : 'text-red-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5 flex-wrap">
            <span class="text-sm font-semibold text-slate-800 truncate"><%= v.imovel ? v.imovel.titulo : '—' %></span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0
              <%= v.status === 'agendada' ? 'bg-yellow-100 text-yellow-700' : v.status === 'realizada' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>">
              <%= v.status %>
            </span>
          </div>
          <div class="text-xs text-slate-500"><%= v.imovel ? v.imovel.bairro + ', ' + v.imovel.cidade : '' %></div>
          <div class="text-xs text-slate-400 mt-0.5">
            🗓 <%= new Date(v.dataHora).toLocaleDateString('pt-BR') %> às <%= new Date(v.dataHora).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %>
          </div>
          <% if (v.observacao) { %>
          <div class="text-xs text-slate-400 mt-0.5 italic"><%= v.observacao %></div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </main>
</div>
</body></html>
