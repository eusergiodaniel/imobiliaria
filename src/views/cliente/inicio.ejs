<%- include('../partials/head', { title: 'Minha Área' }) %>
<%- include('../partials/sidebar_cliente') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0 bg-slate-50">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center justify-between sticky top-14 lg:top-0 z-20">
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800">Olá, <%= usuario.nome.split(' ')[0] %>! 👋</h1>
      <p class="text-xs text-slate-500">Bem-vindo à sua área exclusiva</p>
    </div>
  </header>

  <main class="p-4 lg:p-8">
    <!-- Cards resumo -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-5 mb-6">
      <a href="/cliente/imoveis" class="bg-white rounded-xl p-4 lg:p-5 border border-slate-200 shadow-sm hover:shadow-md transition group">
        <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-blue-100 transition">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        </div>
        <div class="text-2xl font-bold text-slate-800"><%= stats.imoveisDisponiveis %></div>
        <div class="text-xs text-slate-500 mt-0.5">Imóveis disponíveis</div>
      </a>

      <a href="/cliente/visitas" class="bg-white rounded-xl p-4 lg:p-5 border border-slate-200 shadow-sm hover:shadow-md transition group">
        <div class="w-10 h-10 bg-yellow-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-yellow-100 transition">
          <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div class="text-2xl font-bold text-slate-800"><%= stats.minhasVisitas %></div>
        <div class="text-xs text-slate-500 mt-0.5">Minhas visitas</div>
      </a>

      <a href="/cliente/contratos" class="bg-white rounded-xl p-4 lg:p-5 border border-slate-200 shadow-sm hover:shadow-md transition group col-span-2 lg:col-span-1">
        <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-green-100 transition">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <div class="text-2xl font-bold text-slate-800"><%= stats.meusContratos %></div>
        <div class="text-xs text-slate-500 mt-0.5">Meus contratos</div>
      </a>
    </div>

    <!-- Imóveis em destaque -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm mb-5">
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
        <h2 class="font-semibold text-slate-800 text-sm">🏠 Imóveis em Destaque</h2>
        <a href="/cliente/imoveis" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Ver todos →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-slate-100">
        <% const imgMap = { apartamento: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=400&q=80', casa: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400&q=80', comercial: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=400&q=80', terreno: 'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=400&q=80' } %>
        <% if (destaques.length === 0) { %>
          <div class="col-span-3 px-6 py-10 text-center text-slate-400 text-sm">Nenhum imóvel disponível no momento</div>
        <% } %>
        <% destaques.forEach(i => { %>
        <div class="p-4 hover:bg-slate-50 transition">
          <div class="h-28 rounded-lg overflow-hidden mb-3 relative">
            <img src="<%= i.fotoUrl || imgMap[i.tipo] %>" class="w-full h-full object-cover"/>
            <span class="absolute top-1.5 right-1.5 text-xs bg-green-100 text-green-700 font-semibold px-2 py-0.5 rounded-full">disponível</span>
          </div>
          <div class="text-xs text-slate-400 uppercase font-semibold mb-0.5"><%= i.tipo %></div>
          <div class="text-sm font-semibold text-slate-800 truncate mb-1"><%= i.titulo %></div>
          <div class="text-xs text-slate-400 mb-2"><%= i.bairro %>, <%= i.cidade %></div>
          <div class="flex items-center justify-between">
            <span class="text-brand-600 font-bold text-sm">R$ <%= i.preco.toLocaleString('pt-BR') %></span>
            <a href="/cliente/imoveis/<%= i.id %>" class="text-xs bg-brand-600 hover:bg-brand-700 text-white px-3 py-1 rounded-lg transition">Ver mais</a>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Próximas visitas -->
    <% if (proximasVisitas.length > 0) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm">
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
        <h2 class="font-semibold text-slate-800 text-sm">📅 Próximas Visitas</h2>
        <a href="/cliente/visitas" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Ver todas →</a>
      </div>
      <div class="divide-y divide-slate-100">
        <% proximasVisitas.forEach(v => { %>
        <div class="px-5 py-3 flex items-center gap-4">
          <div class="w-10 h-10 bg-yellow-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-slate-800 truncate"><%= v.imovel ? v.imovel.titulo : '—' %></div>
            <div class="text-xs text-slate-400"><%= new Date(v.dataHora).toLocaleDateString('pt-BR') %> às <%= new Date(v.dataHora).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %></div>
          </div>
          <span class="text-xs px-2 py-1 rounded-full font-medium bg-yellow-100 text-yellow-700 flex-shrink-0">agendada</span>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </main>
</div>
</body></html>
