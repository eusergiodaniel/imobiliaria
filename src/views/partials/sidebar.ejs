<!-- Mobile overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-20 lg:hidden hidden" onclick="toggleSidebar()"></div>

<!-- Topbar mobile -->
<div class="lg:hidden fixed top-0 left-0 right-0 z-30 bg-slate-900 flex items-center justify-between px-4 py-3">
  <div class="flex items-center gap-3">
    <button onclick="toggleSidebar()" class="text-white p-1">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 bg-brand-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">I</div>
      <span class="text-white font-semibold text-sm">ImovelHub</span>
    </div>
  </div>
  <div class="text-slate-400 text-xs"><%= usuario ? usuario.nome : '' %></div>
</div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed top-0 left-0 h-screen w-60 bg-slate-900 flex flex-col z-30 transform -translate-x-full lg:translate-x-0 transition-transform duration-200">
  <div class="flex items-center gap-3 px-6 py-5 border-b border-white/10">
    <div class="w-9 h-9 bg-brand-600 rounded-xl flex items-center justify-center text-white font-bold text-lg">I</div>
    <div>
      <div class="text-white font-semibold text-sm leading-tight">ImovelHub</div>
      <div class="text-slate-500 text-xs">Gestão Imobiliária</div>
    </div>
  </div>

  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <p class="text-xs font-semibold text-slate-600 uppercase tracking-wider px-4 mb-2">Menu</p>

    <a href="/painel" onclick="closeSidebar()" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all <%= page === 'dashboard' ? 'text-white bg-brand-600' : 'text-slate-400 hover:text-white hover:bg-white/10' %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Dashboard
    </a>

    <a href="/painel/imoveis" onclick="closeSidebar()" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all <%= page === 'imoveis' ? 'text-white bg-brand-600' : 'text-slate-400 hover:text-white hover:bg-white/10' %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Imóveis
    </a>

    <a href="/painel/clientes" onclick="closeSidebar()" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all <%= page === 'clientes' ? 'text-white bg-brand-600' : 'text-slate-400 hover:text-white hover:bg-white/10' %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Clientes
    </a>

    <a href="/painel/contratos" onclick="closeSidebar()" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all <%= page === 'contratos' ? 'text-white bg-brand-600' : 'text-slate-400 hover:text-white hover:bg-white/10' %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Contratos
    </a>

    <a href="/painel/visitas" onclick="closeSidebar()" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all <%= page === 'visitas' ? 'text-white bg-brand-600' : 'text-slate-400 hover:text-white hover:bg-white/10' %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Visitas
    </a>
  </nav>

  <!-- User -->
  <div class="px-3 py-4 border-t border-white/10">
    <div class="flex items-center gap-3 px-3 py-2">
      <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
        <%= usuario ? usuario.nome.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-white text-xs font-medium truncate"><%= usuario ? usuario.nome : '' %></div>
        <div class="text-slate-500 text-xs truncate"><%= usuario ? usuario.papel : '' %></div>
      </div>
      <a href="/logout" class="text-slate-500 hover:text-red-400 transition-colors flex-shrink-0" title="Sair">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </div>
</aside>

<script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('-translate-x-full')
    document.getElementById('sidebar-overlay').classList.toggle('hidden')
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.add('-translate-x-full')
    document.getElementById('sidebar-overlay').classList.add('hidden')
  }
</script>
