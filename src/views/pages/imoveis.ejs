<%- include('../partials/head', { title: 'Imóveis' }) %>
<%- include('../partials/sidebar') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center justify-between sticky top-14 lg:top-0 z-20">
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800">Imóveis</h1>
      <p class="text-xs text-slate-500"><%= imoveis.length %> imóveis cadastrados</p>
    </div>
    <% if (usuario.papel !== 'cliente') { %>
    <button onclick="document.getElementById('modal-imovel').classList.remove('hidden')"
      class="bg-brand-600 hover:bg-brand-700 text-white text-xs lg:text-sm font-medium px-3 lg:px-4 py-2 rounded-lg transition flex items-center gap-1.5 shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <span class="hidden sm:inline">Novo</span> Imóvel
    </button>
    <% } %>
  </header>

  <main class="p-4 lg:p-8">
    <% if (msg) { %>
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <%= msg %>
    </div>
    <% } %>
    <% if (erro) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"><%= erro %></div>
    <% } %>

    <!-- Filtros -->
    <form method="GET" action="/painel/imoveis" class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 mb-5 flex gap-2 flex-wrap items-end">
      <div class="flex-1 min-w-[100px]">
        <label class="block text-xs font-medium text-slate-600 mb-1">Tipo</label>
        <select name="tipo" class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">Todos</option>
          <option value="apartamento" <%= filtros.tipo==='apartamento'?'selected':'' %>>Apartamento</option>
          <option value="casa"        <%= filtros.tipo==='casa'?'selected':'' %>>Casa</option>
          <option value="comercial"   <%= filtros.tipo==='comercial'?'selected':'' %>>Comercial</option>
          <option value="terreno"     <%= filtros.tipo==='terreno'?'selected':'' %>>Terreno</option>
        </select>
      </div>
      <div class="flex-1 min-w-[100px]">
        <label class="block text-xs font-medium text-slate-600 mb-1">Status</label>
        <select name="status" class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">Todos</option>
          <option value="disponivel" <%= filtros.status==='disponivel'?'selected':'' %>>Disponível</option>
          <option value="reservado"  <%= filtros.status==='reservado'?'selected':'' %>>Reservado</option>
          <option value="vendido"    <%= filtros.status==='vendido'?'selected':'' %>>Vendido</option>
          <option value="alugado"    <%= filtros.status==='alugado'?'selected':'' %>>Alugado</option>
        </select>
      </div>
      <div class="flex-1 min-w-[100px]">
        <label class="block text-xs font-medium text-slate-600 mb-1">Bairro</label>
        <input type="text" name="bairro" value="<%= filtros.bairro||'' %>" placeholder="Ex: Umarizal"
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="bg-slate-800 hover:bg-slate-900 text-white text-sm px-4 py-2 rounded-lg transition whitespace-nowrap">Filtrar</button>
        <a href="/painel/imoveis" class="text-sm text-slate-500 hover:text-slate-700 py-2 whitespace-nowrap">Limpar</a>
      </div>
    </form>

    <!-- Grid -->
    <% if (imoveis.length === 0) { %>
      <div class="text-center py-16 text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        <p class="text-sm">Nenhum imóvel encontrado</p>
      </div>
    <% } %>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 lg:gap-5">
      <% 
        const imgMap = {
          apartamento: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=600&q=80',
          casa:        'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600&q=80',
          comercial:   'https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80',
          terreno:     'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=600&q=80',
        }
      %>
      <% imoveis.forEach(i => { 
        const imgSrc = i.fotoUrl || imgMap[i.tipo] || imgMap.apartamento
      %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition group">
        <div class="h-44 relative overflow-hidden">
          <img src="<%= imgSrc %>" alt="<%= i.titulo %>"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            onerror="this.src='<%= imgMap[i.tipo] || imgMap.apartamento %>'"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <span class="absolute top-2 right-2 text-xs px-2.5 py-1 rounded-full font-semibold backdrop-blur-sm
            <%= i.status === 'disponivel' ? 'bg-green-100/90 text-green-700' :
                i.status === 'reservado'  ? 'bg-yellow-100/90 text-yellow-700' :
                i.status === 'vendido'    ? 'bg-blue-100/90 text-blue-700' :
                                            'bg-slate-100/90 text-slate-600' %>">
            <%= i.status %>
          </span>
          <span class="absolute bottom-2 left-2 text-xs text-white/80 font-medium bg-black/30 backdrop-blur-sm px-2 py-0.5 rounded">
            <%= i.area %> m²
          </span>
        </div>
        <div class="p-4">
          <div class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1"><%= i.tipo %></div>
          <h3 class="font-semibold text-slate-800 text-sm leading-snug mb-1 truncate"><%= i.titulo %></h3>
          <p class="text-xs text-slate-400 mb-3 truncate">
            <svg class="w-3 h-3 inline mr-0.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= i.bairro %>, <%= i.cidade %>
          </p>
          <div class="flex items-center justify-between pt-3 border-t border-slate-100">
            <span class="text-brand-600 font-bold text-sm">R$ <%= i.preco.toLocaleString('pt-BR') %></span>
            <% if (i.descricao) { %>
            <span class="text-xs text-slate-400 truncate max-w-[120px]" title="<%= i.descricao %>"><%= i.descricao.substring(0,30) %>...</span>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </main>
</div>

<!-- Modal Novo Imóvel -->
<div id="modal-imovel" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-2xl sm:rounded-2xl w-full sm:max-w-lg shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl">
      <h2 class="font-semibold text-slate-800">Novo Imóvel</h2>
      <button onclick="document.getElementById('modal-imovel').classList.add('hidden')" class="text-slate-400 hover:text-slate-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="POST" action="/painel/imoveis" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Título *</label>
          <input type="text" name="titulo" required placeholder="Ex: Apartamento 3 quartos"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Tipo *</label>
          <select name="tipo" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="apartamento">Apartamento</option>
            <option value="casa">Casa</option>
            <option value="comercial">Comercial</option>
            <option value="terreno">Terreno</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Preço (R$) *</label>
          <input type="number" name="preco" required placeholder="450000"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Área (m²) *</label>
          <input type="number" name="area" required placeholder="110"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Bairro *</label>
          <input type="text" name="bairro" required placeholder="Umarizal"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Cidade *</label>
          <input type="text" name="cidade" required placeholder="Belém"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Endereço *</label>
          <input type="text" name="endereco" required placeholder="Rua das Flores, 100"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">URL da Foto</label>
          <input type="url" name="fotoUrl" placeholder="https://..."
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
          <p class="text-xs text-slate-400 mt-1">Deixe vazio para usar imagem padrão por tipo</p>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Descrição</label>
          <textarea name="descricao" rows="2" placeholder="Descreva o imóvel..."
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('modal-imovel').classList.add('hidden')"
          class="flex-1 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium py-2.5 rounded-lg transition">Cancelar</button>
        <button type="submit"
          class="flex-1 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 rounded-lg transition">Cadastrar</button>
      </div>
    </form>
  </div>
</div>
</body></html>
