<%- include('../partials/head', { title: 'Visitas' }) %>
<%- include('../partials/sidebar') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center justify-between sticky top-14 lg:top-0 z-20">
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800">Visitas</h1>
      <p class="text-xs text-slate-500"><%= visitas.length %> visitas no sistema</p>
    </div>
    <button onclick="document.getElementById('modal-visita').classList.remove('hidden')"
      class="bg-brand-600 hover:bg-brand-700 text-white text-xs lg:text-sm font-medium px-3 lg:px-4 py-2 rounded-lg transition flex items-center gap-1.5 shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <span class="hidden sm:inline">Agendar</span> Visita
    </button>
  </header>

  <main class="p-4 lg:p-8">
    <% if (msg) { %>
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <%= msg %>
    </div>
    <% } %>
    <% if (erro) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"><%= erro %></div>
    <% } %>

    <% if (visitas.length === 0) { %>
      <div class="text-center py-16 text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-sm">Nenhuma visita agendada</p>
      </div>
    <% } %>

    <!-- Mobile: lista simples -->
    <div class="flex flex-col gap-3 lg:hidden">
      <% visitas.forEach(v => { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center
          <%= v.status === 'agendada' ? 'bg-yellow-100' : v.status === 'realizada' ? 'bg-green-100' : 'bg-red-100' %>">
          <svg class="w-5 h-5 <%= v.status === 'agendada' ? 'text-yellow-600' : v.status === 'realizada' ? 'text-green-600' : 'text-red-500' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center justify-between gap-2 mb-0.5">
            <span class="text-sm font-semibold text-slate-800 truncate"><%= v.imovel ? v.imovel.titulo : '—' %></span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0
              <%= v.status === 'agendada' ? 'bg-yellow-100 text-yellow-700' : v.status === 'realizada' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>">
              <%= v.status %>
            </span>
          </div>
          <div class="text-xs text-slate-500 truncate"><%= v.cliente ? v.cliente.nome : '—' %></div>
          <div class="text-xs text-slate-400 mt-0.5"><%= new Date(v.dataHora).toLocaleDateString('pt-BR') %> às <%= new Date(v.dataHora).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %></div>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Desktop: grid de cards -->
    <div class="hidden lg:grid grid-cols-3 gap-5">
      <% visitas.forEach(v => { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 hover:shadow-md transition">
        <div class="flex items-start justify-between mb-3">
          <span class="text-xs px-2.5 py-1 rounded-full font-medium
            <%= v.status === 'agendada'  ? 'bg-yellow-100 text-yellow-700' :
                v.status === 'realizada' ? 'bg-green-100 text-green-700' :
                                           'bg-red-100 text-red-600' %>">
            <%= v.status %>
          </span>
          <span class="text-xs text-slate-400">
            <%= new Date(v.dataHora).toLocaleDateString('pt-BR') %>
          </span>
        </div>
        <div class="mb-2">
          <div class="text-sm font-semibold text-slate-800 truncate"><%= v.imovel ? v.imovel.titulo : '—' %></div>
          <div class="text-xs text-slate-400"><%= v.imovel ? v.imovel.bairro + ', ' + v.imovel.cidade : '' %></div>
        </div>
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-slate-100">
          <div class="w-6 h-6 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 text-xs font-bold">
            <%= v.cliente ? v.cliente.nome.charAt(0) : 'C' %>
          </div>
          <span class="text-xs text-slate-600"><%= v.cliente ? v.cliente.nome : '—' %></span>
        </div>
        <% if (v.observacao) { %>
        <p class="text-xs text-slate-400 mt-2 italic truncate"><%= v.observacao %></p>
        <% } %>
      </div>
      <% }) %>
    </div>
  </main>
</div>

<!-- Modal Agendar Visita -->
<div id="modal-visita" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-2xl sm:rounded-2xl w-full sm:max-w-md shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl">
      <h2 class="font-semibold text-slate-800">Agendar Visita</h2>
      <button onclick="document.getElementById('modal-visita').classList.add('hidden')" class="text-slate-400 hover:text-slate-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="POST" action="/painel/visitas" class="p-6 space-y-4">
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Imóvel *</label>
        <select name="imovelId" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">Selecione o imóvel</option>
          <% imoveis.forEach(i => { %>
          <option value="<%= i.id %>"><%= i.titulo %> (<%= i.status %>)</option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Cliente *</label>
        <select name="clienteId" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">Selecione o cliente</option>
          <% clientes.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.nome %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Data e Hora *</label>
        <input type="datetime-local" name="dataHora" required
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Observação</label>
        <textarea name="observacao" rows="2" placeholder="Preferências do cliente..."
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('modal-visita').classList.add('hidden')"
          class="flex-1 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium py-2.5 rounded-lg transition">Cancelar</button>
        <button type="submit"
          class="flex-1 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 rounded-lg transition">Agendar</button>
      </div>
    </form>
  </div>
</div>
</body></html>
