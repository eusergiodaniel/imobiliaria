<%- include('../partials/head', { title: 'Contratos' }) %>
<%- include('../partials/sidebar') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center justify-between sticky top-14 lg:top-0 z-20">
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800">Contratos</h1>
      <p class="text-xs text-slate-500"><%= contratos.length %> contratos no sistema</p>
    </div>
    <button onclick="document.getElementById('modal-contrato').classList.remove('hidden')"
      class="bg-brand-600 hover:bg-brand-700 text-white text-xs lg:text-sm font-medium px-3 lg:px-4 py-2 rounded-lg transition flex items-center gap-1.5 shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <span class="hidden sm:inline">Novo</span> Contrato
    </button>
  </header>

  <main class="p-4 lg:p-8">
    <% if (msg) { %>
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <%= msg %>
    </div>
    <% } %>
    <% if (erro) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"><%= erro %></div>
    <% } %>

    <!-- Mobile: cards -->
    <div class="flex flex-col gap-3 lg:hidden">
      <% if (contratos.length === 0) { %>
        <div class="text-center py-12 text-slate-400 text-sm">Nenhum contrato cadastrado</div>
      <% } %>
      <% contratos.forEach(c => { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs px-2.5 py-1 rounded-full font-medium
            <%= c.tipo === 'compra' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
            <%= c.tipo %>
          </span>
          <span class="text-xs px-2.5 py-1 rounded-full font-medium
            <%= c.status === 'ativo' ? 'bg-green-100 text-green-700' : c.status === 'encerrado' ? 'bg-slate-100 text-slate-600' : 'bg-red-100 text-red-600' %>">
            <%= c.status %>
          </span>
        </div>
        <div class="text-sm font-semibold text-slate-800 truncate mb-0.5"><%= c.imovel ? c.imovel.titulo : '—' %></div>
        <div class="text-xs text-slate-500 mb-2"><%= c.cliente ? c.cliente.nome : '—' %></div>
        <div class="flex items-center justify-between pt-2 border-t border-slate-100">
          <span class="text-brand-600 font-bold text-sm">R$ <%= c.valorTotal.toLocaleString('pt-BR') %></span>
          <span class="text-xs text-slate-400"><%= new Date(c.dataInicio).toLocaleDateString('pt-BR') %></span>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Desktop: tabela -->
    <div class="hidden lg:block bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Tipo</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Imóvel</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Cliente</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Valor</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Início</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (contratos.length === 0) { %>
          <tr><td colspan="6" class="px-6 py-10 text-center text-slate-400">Nenhum contrato cadastrado</td></tr>
          <% } %>
          <% contratos.forEach(c => { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-6 py-3.5">
              <span class="text-xs px-2.5 py-1 rounded-full font-medium
                <%= c.tipo === 'compra' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                <%= c.tipo %>
              </span>
            </td>
            <td class="px-6 py-3.5 text-slate-700 font-medium truncate max-w-[180px]"><%= c.imovel ? c.imovel.titulo : '—' %></td>
            <td class="px-6 py-3.5 text-slate-500"><%= c.cliente ? c.cliente.nome : '—' %></td>
            <td class="px-6 py-3.5 text-brand-600 font-semibold">R$ <%= c.valorTotal.toLocaleString('pt-BR') %></td>
            <td class="px-6 py-3.5 text-slate-400 text-xs"><%= new Date(c.dataInicio).toLocaleDateString('pt-BR') %></td>
            <td class="px-6 py-3.5">
              <span class="text-xs px-2.5 py-1 rounded-full font-medium
                <%= c.status === 'ativo' ? 'bg-green-100 text-green-700' : c.status === 'encerrado' ? 'bg-slate-100 text-slate-600' : 'bg-red-100 text-red-600' %>">
                <%= c.status %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<!-- Modal Novo Contrato -->
<div id="modal-contrato" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-2xl sm:rounded-2xl w-full sm:max-w-md shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl">
      <h2 class="font-semibold text-slate-800">Novo Contrato</h2>
      <button onclick="document.getElementById('modal-contrato').classList.add('hidden')" class="text-slate-400 hover:text-slate-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="POST" action="/painel/contratos" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Tipo *</label>
          <select name="tipo" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="compra">Compra</option>
            <option value="locacao">Locação</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Valor (R$) *</label>
          <input type="number" name="valorTotal" required placeholder="450000"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Imóvel *</label>
          <select name="imovelId" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Selecione um imóvel disponível</option>
            <% imoveisDisponiveis.forEach(i => { %>
            <option value="<%= i.id %>"><%= i.titulo %> — R$ <%= i.preco.toLocaleString('pt-BR') %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Cliente *</label>
          <select name="clienteId" required class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Selecione um cliente</option>
            <% clientes.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.nome %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Data Início *</label>
          <input type="date" name="dataInicio" required
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Data Fim</label>
          <input type="date" name="dataFim"
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Observação</label>
          <textarea name="observacao" rows="2" placeholder="Detalhes do contrato..."
            class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('modal-contrato').classList.add('hidden')"
          class="flex-1 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium py-2.5 rounded-lg transition">Cancelar</button>
        <button type="submit"
          class="flex-1 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 rounded-lg transition">Criar Contrato</button>
      </div>
    </form>
  </div>
</div>
</body></html>
