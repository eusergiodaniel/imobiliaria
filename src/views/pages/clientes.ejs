<%- include('../partials/head', { title: 'Clientes' }) %>
<%- include('../partials/sidebar') %>

<div class="lg:ml-60 min-h-screen pt-14 lg:pt-0">
  <header class="bg-white border-b border-slate-200 px-4 lg:px-8 py-4 flex items-center justify-between sticky top-14 lg:top-0 z-20">
    <div>
      <h1 class="text-base lg:text-lg font-semibold text-slate-800">Clientes</h1>
      <p class="text-xs text-slate-500"><%= clientes.length %> clientes cadastrados</p>
    </div>
    <button onclick="document.getElementById('modal-cliente').classList.remove('hidden')"
      class="bg-brand-600 hover:bg-brand-700 text-white text-xs lg:text-sm font-medium px-3 lg:px-4 py-2 rounded-lg transition flex items-center gap-1.5 shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <span class="hidden sm:inline">Novo</span> Cliente
    </button>
  </header>

  <main class="p-4 lg:p-8">
    <% if (msg) { %>
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <%= msg %>
    </div>
    <% } %>
    <% if (erro) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"><%= erro %></div>
    <% } %>

    <!-- Mobile: cards -->
    <div class="flex flex-col gap-3 lg:hidden">
      <% if (clientes.length === 0) { %>
        <div class="text-center py-12 text-slate-400 text-sm">Nenhum cliente cadastrado</div>
      <% } %>
      <% clientes.forEach(c => { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-bold text-sm flex-shrink-0">
          <%= c.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-semibold text-slate-800 truncate"><%= c.nome %></div>
          <div class="text-xs text-slate-500 truncate"><%= c.email %></div>
          <div class="text-xs text-slate-400 mt-0.5"><%= c.telefone || 'Sem telefone' %> · CPF: <%= c.cpf %></div>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Desktop: tabela -->
    <div class="hidden lg:block bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Nome</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">E-mail</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Telefone</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">CPF</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Cadastro</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (clientes.length === 0) { %>
          <tr><td colspan="5" class="px-6 py-10 text-center text-slate-400">Nenhum cliente cadastrado</td></tr>
          <% } %>
          <% clientes.forEach(c => { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-6 py-3.5">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-semibold text-xs">
                  <%= c.nome.charAt(0).toUpperCase() %>
                </div>
                <span class="font-medium text-slate-800"><%= c.nome %></span>
              </div>
            </td>
            <td class="px-6 py-3.5 text-slate-500"><%= c.email %></td>
            <td class="px-6 py-3.5 text-slate-500"><%= c.telefone || '—' %></td>
            <td class="px-6 py-3.5 text-slate-500 font-mono text-xs"><%= c.cpf %></td>
            <td class="px-6 py-3.5 text-slate-400 text-xs"><%= new Date(c.criadoEm).toLocaleDateString('pt-BR') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<!-- Modal Novo Cliente -->
<div id="modal-cliente" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-2xl sm:rounded-2xl w-full sm:max-w-md shadow-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 sticky top-0 bg-white rounded-t-2xl">
      <h2 class="font-semibold text-slate-800">Novo Cliente</h2>
      <button onclick="document.getElementById('modal-cliente').classList.add('hidden')" class="text-slate-400 hover:text-slate-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="POST" action="/painel/clientes" class="p-6 space-y-4">
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Nome completo *</label>
        <input type="text" name="nome" required placeholder="João Silva"
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">E-mail *</label>
        <input type="email" name="email" required placeholder="joao@email.com"
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">CPF * (somente números)</label>
        <input type="text" name="cpf" required placeholder="12345678901" maxlength="11"
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-700 mb-1">Telefone</label>
        <input type="text" name="telefone" placeholder="91999990001"
          class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500"/>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('modal-cliente').classList.add('hidden')"
          class="flex-1 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium py-2.5 rounded-lg transition">Cancelar</button>
        <button type="submit"
          class="flex-1 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 rounded-lg transition">Cadastrar</button>
      </div>
    </form>
  </div>
</div>
</body></html>
